{
  "name": "@anterior/watchdawg",
  "version": "0.0.5",
  "description": "workflow agent watchdog to guarantee delivery",
  "type": "module",
  "license": "AGPL-3.0-only",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": "git+https://github.com/anteriorcore/watchdawg",
  "bin": {
    "demo-main": "src/test/demo-main.ts",
    "integration-test": "src/test/integration-test.ts"
  },
  "scripts": {
    "build": "tsc",
    "demo": "node ./src/test/demo-main.ts",
    "integration": "node .src/test/integration-test.ts",
    "test": "node --test src/**/*.test.ts",
    "test:unit": "node --test src/**/*.test.ts",
    "prepack": "for f in ../../README.md ../../LICENSE ; do [ -f $f ] && cp $f . ; done"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.982.0",
    "bencode": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bencode": "^2.0.4",
    "@types/node": "^25.2.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "zod": "^4.1.12"
  }
}
